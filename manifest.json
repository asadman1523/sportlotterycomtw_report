{
  "manifest_version": 3,
  "name": "運彩視覺化UI",
  "version": "1.0.5",
  "description": "自動統計與彙整台灣運彩歷史投注報表",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://member.sportslottery.com.tw/*",
        "https://www-talo-ssb-pr.sportslottery.com.tw/*"
      ],
      "js": [
        "sportslottery-my-bets.user.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "128": "icon128.png"
  },
  "host_permissions": [],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
