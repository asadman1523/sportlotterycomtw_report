{
  "manifest_version": 3,
  "name": "台灣運彩投注報表",
  "version": "1.0.0",
  "description": "自動統計與彙整台灣運彩30天內的歷史投注報表",
  "content_scripts": [
    {
      "matches": [
        "https://member.sportslottery.com.tw/*",
        "https://www-talo-ssb-pr.sportslottery.com.tw/*"
      ],
      "js": [
        "sportslottery-my-bets.user.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "host_permissions": [],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
